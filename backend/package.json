{
  "name": "ecom-backend",
  "version": "1.0.0",
  "description": "E-Commerce Platform Backend",
  "type": "module",
  "main": "src/app.js",
  "scripts": {
"start": "npx prisma db push && npx prisma db seed && node src/app.js",
    "dev": "nodemon src/app.js",
"test": "cross-env NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles --forceExit"  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    }
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.24.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^3.0.0",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.12.1",
    "supertest": "^7.2.2"
  }
}
